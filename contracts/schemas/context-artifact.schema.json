{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.context-governance-gateway.local/context-artifact.schema.json",
  "title": "Context Artifact",
  "type": "object",
  "required": ["artifact_id", "artifact_digest", "captured_at", "source"],
  "properties": {
    "artifact_id": {"type": "string"},
    "artifact_digest": {"type": "string", "pattern": "^sha256:[a-f0-9]{64}$"},
    "captured_at": {"type": "string"},
    "source": {"type": "object"}
  },
  "additionalProperties": true
}
